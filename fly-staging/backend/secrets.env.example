# Musely staging — backend secrets (musely-staging-backend)
#
# Setup:
#   cp secrets.env.example secrets.env
#   # edit secrets.env — only KEY=value lines, no comments
#   fly secrets import < secrets.env --config fly.toml
#   # or from repo root:
#   ./scripts/fly-secrets-import.sh fly-staging/backend
#
# Generate values:
#   openssl rand -hex 32          → SESSION_SECRET, AGENT_API_KEY
#   fly tokens create deploy      → FLY_API_TOKEN

SESSION_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://musely-staging-backend.fly.dev/api/auth/google/callback
CLIENT_URL=https://musely-staging-frontend.fly.dev
AGENT_API_KEY=
FLY_API_TOKEN=
# OPENROUTER_API_KEY=
