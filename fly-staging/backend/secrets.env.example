# Musely staging — backend secrets (musely-staging-backend)
#
# Setup:
#   cp secrets.env.example secrets.env
#   # edit secrets.env — only KEY=value lines, no comments
#   fly secrets import < secrets.env --config fly.toml
#   # or from repo root:
#   ./scripts/fly-secrets-import.sh fly-staging/backend
#
# Generate values:
#   openssl rand -hex 32                              → SESSION_SECRET, AGENT_API_KEY
#   fly tokens create org -o <org> -n musely-staging  → FLY_API_TOKEN (org-scoped; same token as GitHub secret FLY_API_TOKEN_STAGING)

SESSION_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://staging.musely.tech/api/auth/google/callback
CLIENT_URL=https://staging.musely.tech

AGENT_API_KEY=
FLY_API_TOKEN=
# Org-scoped token (fly tokens create org). Can match GitHub secret FLY_API_TOKEN_STAGING.
# OPENROUTER_API_KEY=
