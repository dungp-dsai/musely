# Musely staging — frontend (musely-staging-frontend)
#
# This app usually needs no secrets. BACKEND_URL is set in fly.toml [env].
# Keep this file only if you add secrets later (e.g. basic auth).
#
# Setup (if you add secrets):
#   cp secrets.env.example secrets.env
#   fly secrets import < secrets.env --config fly.toml
