# Copy to .env:
#   cp .env.docker.example .env

# --- writer-app (port 8080) ---
WRITER_PORT=8080

# LLM for in-app task chat on highlighted passages (optional)
OPENROUTER_API_KEY=
# OPENAI_API_KEY=

# --- Hermes Agent API server (port 8642) — must match in both containers ---
# REQUIRED: min 16 chars when API_SERVER_HOST=0.0.0.0 (Hermes refuses weak keys)
# Generate: openssl rand -hex 32
HERMES_API_SERVER_KEY=change-me-use-openssl-rand-hex-32
HERMES_API_MODEL_NAME=Hermes Agent
HERMES_API_PORT=8642

# Optional resource limits for Hermes (browser tools need ~2GB+ RAM)
# HERMES_MEMORY_LIMIT=4G
# HERMES_CPU_LIMIT=2.0

# Optional model override for built-in chat UI
# HERMES_CHAT_MODEL=hermes-agent
