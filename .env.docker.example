# Copy to .env:
#   cp .env.docker.example .env

# --- Web UI (nginx) ---
WRITER_PORT=8080
CLIENT_URL=http://localhost:8080

# --- PostgreSQL ---
POSTGRES_USER=writer
POSTGRES_PASSWORD=writer
POSTGRES_DB=writer

# --- Auth (required) ---
# Generate: openssl rand -hex 32
SESSION_SECRET=change-me-use-openssl-rand-hex-32

# Google Cloud Console → OAuth 2.0 Client (Web application)
# Authorized redirect URI must match GOOGLE_CALLBACK_URL
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8080/api/auth/google/callback

# --- Agent API (Hermes agent-cli / HTTP agent routes) ---
# Generate: openssl rand -hex 32
AGENT_API_KEY=
# Optional: scope Hermes agent to one user's posts
# AGENT_USER_ID=1

# --- LLM for in-app task chat (optional — Hermes uses ./hermes-data/.env) ---
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=

# --- Hermes template (per-user containers clone from hermes-data) ---
# Run hermes setup once so ./hermes-data/.env exists with your LLM provider keys.
# The orchestrator copies that .env into each user's isolated volume.
# REQUIRED: min 16 chars when API_SERVER_HOST=0.0.0.0
# Generate: openssl rand -hex 32
HERMES_API_SERVER_KEY=change-me-use-openssl-rand-hex-32
HERMES_API_MODEL_NAME=Hermes Agent

# Optional model override for built-in chat UI
# HERMES_CHAT_MODEL=hermes-agent

# --- Per-user Hermes orchestrator ---
# Each signed-in user gets an isolated Hermes container (hermes-<google-name>-<id>)
# seeded from ./hermes-data (preferred) or ./hermes-base, started on demand.
# Each ACTIVE user consumes ~HERMES_USER_MEMORY of RAM — budget accordingly.
HERMES_IMAGE=nousresearch/hermes-agent:latest
# Stop a user's instance after this many idle minutes (scheduled cron jobs
# only run while the instance is active).
HERMES_IDLE_MINUTES=15
# Per-user container resource caps
HERMES_USER_MEMORY=4g
HERMES_USER_CPUS=2.0
# Set HERMES_ORCHESTRATOR=disabled to fall back to a single shared Hermes
