# Copy to .env next to docker-compose.yml on your VPS:
#   cp .env.docker.example .env

# Host port mapped to the container (default 8080)
WRITER_PORT=8080

# LLM for in-app task chat (set at least one)
OPENROUTER_API_KEY=
# OPENAI_API_KEY=

# Optional model override for task chat
# WRITER_CHAT_MODEL=anthropic/claude-sonnet-4
