# Musely — local dev environment
# Copy to .env in the repo root:  cp .env.example .env
# The backend loads this file via --env-file-if-exists=../../.env

# ── Backend API server ────────────────────────────────────────────────────────
PORT=8081
HOST=0.0.0.0
CLIENT_URL=http://localhost:5173

# ── Database (SQLite) ─────────────────────────────────────────────────────────
# Path to the SQLite database file.
# In local dev this resolves relative to apps/backend/; on Fly it points at the
# mounted volume (set in fly.toml: DB_PATH=/data/musely.db).
DB_PATH=./data/musely.db

# ── Auth (session cookies) ────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
SESSION_SECRET=dev-change-me-use-openssl-rand-hex-32

# Google Cloud Console → Credentials → OAuth 2.0 Client (Web application)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Local dev callback (add to Google OAuth allowed redirect URIs):
GOOGLE_CALLBACK_URL=http://localhost:8081/api/auth/google/callback

# ── Agent API ─────────────────────────────────────────────────────────────────
# Shared secret for Hermes machines to call back into the backend.
# Generate: openssl rand -hex 32
AGENT_API_KEY=
# Restrict agent access to a single user (leave empty for multi-user):
# AGENT_USER_ID=

# ── Task chat (highlighted-passage AI replies) ────────────────────────────────
# One of OpenRouter or OpenAI key is needed for task-chat replies.
# OPENROUTER_API_KEY=sk-or-...
# OPENAI_API_KEY=sk-...
# WRITER_CHAT_MODEL=anthropic/claude-sonnet-4-5

# ── Fly Machines orchestrator (per-user Hermes agents) ───────────────────────
# Leave MACHINES_API_TOKEN empty in local dev — orchestrator is disabled automatically.
# (FLY_API_TOKEN works as a local alias; do NOT use that name as a Fly secret — Fly strips it.)
#
# MACHINES_API_TOKEN=     Org token for Machines API (fly tokens create org)
# FLY_AGENT_APP=musely-staging-agent
# FLY_AGENT_IMAGE=registry.fly.io/musely-staging-agent:latest
# FLY_AGENT_REGION=sin
# FLY_API_HOSTNAME=api.machines.dev
# HERMES_IDLE_MINUTES=15
# HERMES_USER_MEMORY_MB=2048
# HERMES_USER_CPUS=1
# HERMES_API_MODEL_NAME=Hermes Agent
# HERMES_HEALTH_TIMEOUT_MS=180000
# HERMES_PORT=8642

# ── Frontend (Vite dev proxy is used by default; set only for standalone builds)
# VITE_API_URL=http://localhost:8081
