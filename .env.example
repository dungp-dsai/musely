# Local dev — copy to .env in the project root:
#   cp .env.example .env

# --- PostgreSQL (local or Docker) ---
DATABASE_URL=postgresql://writer:writer@localhost:5432/writer

# --- API server ---
PORT=8081
CLIENT_URL=http://localhost:5173

# --- Auth ---
# Generate: openssl rand -hex 32
SESSION_SECRET=dev-change-me-use-openssl-rand-hex-32

# Google Cloud Console → OAuth 2.0 Client (Web application)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8081/api/auth/google/callback

# --- Agent API (Hermes agent-cli) ---
AGENT_API_KEY=
# AGENT_USER_ID=

# --- Hermes chat proxy ---
# HERMES_API_BASE_URL=http://127.0.0.1:8642/v1
# HERMES_API_SERVER_KEY=your-local-dev-key

# --- Task chat on highlighted passages ---
# OPENROUTER_API_KEY=sk-or-...
# OPENAI_API_KEY=sk-...

# Frontend (optional — leave empty when using Vite proxy)
# VITE_API_URL=http://localhost:8081

# --- Hermes cron (local dev with native hermes CLI) ---
# HERMES_DATA_DIR=./hermes-data
# HERMES_CRON_MODE=local
# Docker uses HERMES_CRON_MODE=docker + docker socket (see docker-compose.yml)
