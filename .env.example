# Local dev — copy to .env in the project root:
#   cp .env.example .env

# Optional: override Hermes API (defaults to http://127.0.0.1:8642/v1)
# HERMES_API_BASE_URL=http://127.0.0.1:8642/v1

# Optional if not using ~/.hermes/.env
# HERMES_API_SERVER_KEY=your-local-dev-key

# Task chat on highlighted passages (or set in ~/.hermes/.env)
# OPENROUTER_API_KEY=sk-or-...
# OPENAI_API_KEY=sk-...
