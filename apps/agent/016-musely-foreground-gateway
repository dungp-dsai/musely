#!/command/with-contenv sh
# shellcheck shell=sh
# Legacy: when HERMES_GATEWAY_NO_SUPERVISE=1, Hermes reconcile can race a
# foreground gateway and the machine exits with code 1. Reset state to stopped.
#
# Current Musely uses Hermes default supervised `gateway run` (no --no-supervise),
# so this script is a no-op unless someone still opts into foreground mode.
case "${HERMES_GATEWAY_NO_SUPERVISE:-}" in
    1|true|TRUE|True|yes|YES|Yes) ;;
    *) exit 0 ;;
esac

HERMES_HOME="${HERMES_HOME:-/opt/data}"
/opt/hermes/.venv/bin/python - <<'PY'
import json, os, time
from pathlib import Path

home = Path(os.environ.get("HERMES_HOME", "/opt/data"))
state = home / "gateway_state.json"
state.write_text(
    json.dumps(
        {
            "gateway_state": "stopped",
            "desired_state": "stopped",
            "timestamp": int(time.time()),
            "musely": "foreground-gateway-reset",
        }
    )
    + "\n"
)
print("[musely] reset gateway_state.json to stopped (foreground gateway mode)")
PY
